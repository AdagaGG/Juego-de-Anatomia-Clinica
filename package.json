{
  "name": "monitor-vital-dra-perfinka",
  "version": "1.0.0",
  "description": "Juego educativo: Monitor Vital con Dra. Perfinka - Trivia de Anatomía Clínica",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --no-sandbox",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build-win": "electron-builder --win --publish never",
    "build-mac": "electron-builder --mac --publish never",
    "build-linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.monitorgame.perfinka",
    "productName": "Monitor Vital: Dra. Perfinka",
    "files": [
      "index.html",
      "style.css",
      "script.js",
      "main.js",
      "preload.js",
      "doctor-*.png"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "game",
    "education",
    "anatomy",
    "medical",
    "quiz"
  ],
  "author": "Adrian",
  "license": "MIT",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
